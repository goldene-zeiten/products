{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/payment/paypal/v2/checkout/orders",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.purchase_units[0].amount.value",
          "equalTo": "0.00"
        }
      }
    ]
  },
  "response": {
    "status": 422,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "name": "UNPROCESSABLE_ENTITY",
      "details": [
        {
          "field": "/purchase_units/@reference_id=='default'/amount/value",
          "issue": "INVALID_CURRENCY_CODE"
        }
      ],
      "message": "The requested action could not be performed."
    }
  }
}
