{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/payment/paypal/v1/notifications/verify-webhook-signature",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.webhook_id",
          "equalTo": "WEBHOOK-OK"
        }
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "verification_status": "SUCCESS"
    }
  }
}
