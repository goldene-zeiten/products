includes:
  - ../../../.Build/vendor/saschaegerer/phpstan-typo3/extension.neon
  - ../phpstan-baseline.neon

parameters:
  # Use local .cache dir instead of /tmp
  tmpDir: ../../../.cache/phpstan
  ignoreErrors:
    - '#Variable \$_EXTKEY might not be defined\.#'
  level: 8

  paths:
    - ../../../packages/goldene-zeiten/products-core/Classes
    - ../../../packages/goldene-zeiten/products-core/Configuration
    - ../../../packages/goldene-zeiten/products-core/Core13
    - ../../../packages/goldene-zeiten/products-core/Tests
    - ../../../packages/goldene-zeiten/products-core/ext_emconf.php
    - ../../../packages/goldene-zeiten/products-core/ext_localconf.php
