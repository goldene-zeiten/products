{
  "name": "goldene-zeiten/products",
  "description": "TYPO3 Shop system",
  "type": "typo3-cms-extension",
  "license": [
    "GPL-2.0-or-later"
  ],
  "config": {
    "vendor-dir": ".Build/vendor",
    "sort-packages": true,
    "bin-dir": ".Build/bin",
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true,
      "sbuerk/fixture-packages": true
    }
  },
  "autoload": {
    "psr-4": {
      "GoldeneZeiten\\Products\\": "Classes/",
      "GoldeneZeiten\\Products\\Core13\\": "Core13/",
      "GoldeneZeiten\\Products\\Core14\\": "Core14/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GoldeneZeiten\\Products\\Tests\\": "Tests/"
    }
  },
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4 || ^8.5",
    "ext-intl": "*",
    "typo3/cms-backend": "^13.4 || ^14.3",
    "typo3/cms-core": "^13.4 || ^14.3",
    "typo3/cms-fluid": "^13.4 || ^14.3",
    "typo3/cms-frontend": "^13.4 || ^14.3",
    "typo3/cms-install": "^13.4 || ^14.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "helmich/typo3-typoscript-lint": "^3.3",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11",
    "saschaegerer/phpstan-typo3": "^2.1.1 || ^3.0.1",
    "sbuerk/fixture-packages": "^1.1",
    "sbuerk/typo3-site-based-test-trait": "^2.0 || ^3.0",
    "symfony/translation": "^7.4 || ^8.1",
    "typo3/cms-lowlevel": "^13.4 || ^14.3",
    "typo3/cms-tstemplate": "^13.4 || ^14.3",
    "typo3/testing-framework": "^9.0"
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "products",
      "web-dir": ".Build/Web",
      "version": "1.0.0",
      "Package": {
        "providesPackages": {}
      }
    },
    "sbuerk/fixture-packages": {
      "paths": [
        "Tests/Functional/Fixtures/Extensions/*"
      ]
    }
  }
}
