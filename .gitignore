/.Build
/.cache
/public
/original
/var
# TYPO3 14's Environment/ClassLoadingInformation hardcode "packages/{ext,sysext,
# PackageStates.php,autoload-tests}" next to composer.json whenever project path != public
# path (true here, since web-dir is .Build/Web) - not redirectable via TYPO3_PATH_ROOT/
# TYPO3_PATH_WEB or any composer.json setting, see Build/Scripts/runTests.sh's "unit" suite.
/packages/autoload-tests
/.claude
# Rendered documentation and build caches are generated per package, not only at the root.
Documentation-GENERATED-temp/
.Build/
composer.lock
node_modules/
/.playwright-mcp/
/.idea
/.vscode

# Disposable acceptance-test instance - rebuilt fresh by Tests/Acceptance/setupInstance.sh
# Playwright's stored login session state, regenerated by the "login" project each run
/Tests/Acceptance/.auth/
