{
  "name": "goldene-zeiten/products-payment-stripe",
  "description": "Stripe Checkout payment method for the Products TYPO3 shop system",
  "type": "typo3-cms-extension",
  "license": [
    "GPL-2.0-or-later"
  ],
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4 || ^8.5",
    "ext-json": "*",
    "goldene-zeiten/products-api-client": "^1.0",
    "goldene-zeiten/products-core": "^1.0",
    "psr/http-message": "^1.1 || ^2.0",
    "stripe/stripe-php": "^17.0",
    "typo3/cms-core": "^13.4 || ^14.3",
    "typo3/cms-extbase": "^13.4 || ^14.3"
  },
  "autoload": {
    "psr-4": {
      "GoldeneZeiten\\Products\\Payment\\Stripe\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GoldeneZeiten\\Products\\Payment\\Stripe\\Tests\\": "Tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "products_payment_stripe",
      "version": "1.0.0",
      "Package": {
        "providesPackages": {
          "stripe/stripe-php": "Resources/Private/Php/ComposerVendor"
        }
      }
    },
    "branch-alias": {
      "dev-main": "1.0.x-dev"
    }
  }
}
