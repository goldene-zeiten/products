{
    "name": "@goldene-zeiten/products-monorepo",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Build and test toolchain for the products monorepo",
    "workspaces": [
        "packages/*/*/Build"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "lint:js": "eslint .",
        "lint:js:fix": "eslint . --fix",
        "test:acceptance": "playwright test --config=Tests/Acceptance/playwright.config.js"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "1.61.1",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.7.0",
        "prettier": "^3.9.4",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.63.0"
    }
}
